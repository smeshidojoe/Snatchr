# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# ---- Сборка / обновление ----
build/
dist/
_update/          # скачанный апдейт рядом с программой
*.manifest
*.spec            # авто-сгенерированные spec'и игнорируем,
!Snatchr.spec     # но наш рецепт сборки держим в репозитории.

